<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GNAIAAAC LLC | ssgpt6.com</title>
    <style>
        :root { --public-blue: #0052cc; --gov-red: #d93025; --bg-black: #0a0a0a; }
        body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg-black); color: white; margin: 0; overflow: hidden; }
        
        /* Master Header */
        .gnaiaaac-header { 
            display: flex; justify-content: space-between; align-items: center; 
            padding: 15px 30px; background: #111; border-bottom: 2px solid #333; 
        }
        .brand { font-size: 1.2rem; font-weight: 900; letter-spacing: 2px; color: #fff; }
        
        .nav-hub { display: flex; gap: 15px; }
        .btn { padding: 12px 24px; border: none; cursor: pointer; font-weight: 700; border-radius: 4px; transition: 0.2s ease-in-out; text-transform: uppercase; font-size: 0.85rem; }
        
        .public-btn { background: var(--public-blue); color: white; border: 1px solid #0066ff; }
        .restricted-btn { background: var(--gov-red); color: white; border: 1px solid #ff4d4d; }
        .btn:hover { filter: brightness(1.2); transform: scale(1.02); }
        .btn:active { transform: scale(0.98); }

        /* Content Area */
        #view-container { width: 100vw; height: calc(100vh - 80px); position: relative; }
        iframe { width: 100%; height: 100%; border: none; position: absolute; top: 0; left: 0; }
        .hidden { display: none; visibility: hidden; z-index: -1; }
        .active { display: block; visibility: visible; z-index: 10; }

        /* Security Overlay */
        #security-shutter {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.95); z-index: 9999; display: flex;
            flex-direction: column; justify-content: center; align-items: center;
        }
    </style>
</head>
<body>

    <header class="gnaiaaac-header">
        <div class="brand">GNAIAAAC LLC</div>
        <div class="nav-hub">
            <button class="btn public-btn" onclick="switchFace('public')">Public Infrastructure</button>
            <button class="btn restricted-btn" onclick="switchFace('restricted')">Sovereign Vault (NASA/UN)</button>
        </div>
    </header>

    <main id="view-container">
        <iframe id="face-public" class="active" src="https://ssgpt-dashboard.replit.app/gnaiaaac-site/"></iframe>
        
        <iframe id="face-restricted" class="hidden" src="about:blank"></iframe>
    </main>

    <script>
        const protocols = {
            public: "https://ssgpt-dashboard.replit.app/gnaiaaac-site/",
            restricted: "https://cyber-fortress--shanta4190.replit.app"
        };

        function switchFace(target) {
            const pubFrame = document.getElementById('face-public');
            const resFrame = document.getElementById('face-restricted');

            if (target === 'public') {
                pubFrame.classList.add('active'); pubFrame.classList.remove('hidden');
                resFrame.classList.add('hidden'); resFrame.classList.remove('active');
                resFrame.src = "about:blank"; // Purge restricted data from memory
            } else {
                // SOVEREIGN SHIELD CHALLENGE
                const auth = confirm("WARNING: You are accessing a US Government restricted portal. Unauthorized access is prohibited by federal law. Proceed with PIV/CAC verification?");
                
                if (auth) {
                    const pass = prompt("Enter Sovereign Encryption Key:");
                    if (pass === "NASA_UN_GNAI_2026") { // Placeholder for Cloudflare Zero Trust
                        resFrame.src = protocols.restricted;
                        resFrame.classList.add('active'); resFrame.classList.remove('hidden');
                        pubFrame.classList.add('hidden'); pubFrame.classList.remove('active');
                    } else {
                        alert("AUTHENTICATION FAILURE: Access Denied.");
                    }
                }
            }
        }
    </script>
</body>
</html>
