* {
  box-sizing: border-box;
  padding: 0;
  margin: 0;
}

body {
  font-family: Arial, Helvetica, sans-serif;
  background: #0b1220;
  color: #ffffff;
  line-height: 1.6;
}

main {
  max-width: 900px;
  margin: auto;
}

h1 {
  font-size: 40px;
  margin-bottom: 20px;
  color: #f5c542;
}

h2 {
  margin-top: 30px;
  margin-bottom: 10px;
  color: #f5c542;
}

p {
  margin-bottom: 10px;
}

ul {
  padding-left: 20px;
  margin-bottom: 20px;
}

li {
  margin-bottom: 6px;
}