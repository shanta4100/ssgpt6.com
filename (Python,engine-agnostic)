# career_climber_model.py

from dataclasses import dataclass, field
from enum import Enum, auto
from typing import List


class Tier(Enum):
    STUDENT = auto()
    PROFESSIONAL = auto()
    TYCOON = auto()


@dataclass
class Stats:
    energy: int = 10
    max_energy: int = 10
    study_xp: int = 0
    career_xp: int = 0
    legacy_xp: int = 0
    reputation: int = 0
    skill_points: int = 0


@dataclass
class PlayerState:
    name: str
    tier: Tier = Tier.STUDENT
    day: int = 1
    stats: Stats = field(default_factory=Stats)
    log: List[str] = field(default_factory=lambda: ["A new life path begins."])
